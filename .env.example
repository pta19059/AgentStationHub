# Copy to '.env' and fill in. docker-compose automatically picks up this file.

# ---- Azure OpenAI (required) ----
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_RUNNER_DEPLOYMENT=gpt-5.3-chat

# ---- Azure auth (optional, pick ONE) ----
# A) Use AAD via your host's `az login` (recommended):
#    leave AZURE_OPENAI_API_KEY empty and make sure you ran `az login` on the
#    host BEFORE starting the stack. The ~/.azure bind-mount takes care of
#    the rest. Pin the tenant only when your account is multi-tenant:
# AZURE_TENANT_ID=

# B) Fall back to a static API key (dev / CI scenarios):
# AZURE_OPENAI_API_KEY=
