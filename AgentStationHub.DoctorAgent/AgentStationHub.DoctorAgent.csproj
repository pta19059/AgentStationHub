<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <RootNamespace>AgentStationHub.DoctorAgent</RootNamespace>
    <AssemblyName>doctor-agent</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <NoWarn>$(NoWarn);NU1903;NU1605</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- Foundry hosted-agent runtime adapters. Versions tracked from
         the official invocations-echo-agent sample as of 2026-04-25. -->
    <PackageReference Include="Microsoft.Agents.AI.Foundry.Hosting" Version="1.2.0-preview.260421.1" />
    <PackageReference Include="Azure.AI.AgentServer.Invocations" Version="1.0.0-beta.3" />

    <!-- LLM transport. We talk to the same Foundry account that hosts us
         (deployment ash-doctor � o4-mini), reached via the project's
         managed identity. Bumped to 2.9.0-beta.1 to match the OpenAI
         transitive dep (Microsoft.Agents.AI.Foundry.Hosting pulls
         OpenAI 2.10.0 which DROPPED RealtimeConversationClient � the
         older Azure.AI.OpenAI 2.2.0-beta.4 referenced that type and
         crashed at runtime with TypeLoadException inside GetChatClient).
         OpenAI is pinned to 2.9.1 explicitly to keep the type present;
         AzureOpenAIClient's pipeline doesn't actually use realtime in
         our code path, but the option-resolution code path checks the
         type at runtime and must be able to load it. -->
    <PackageReference Include="Azure.AI.OpenAI" Version="2.9.0-beta.1" />
    <PackageReference Include="OpenAI" Version="2.9.1" />
    <PackageReference Include="Azure.Identity" Version="1.15.0" Aliases="AzId" />
  </ItemGroup>

</Project>
